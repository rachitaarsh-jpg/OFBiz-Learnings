<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Form" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Form http://ofbiz.apache.org/dtds/widget-form.xsd">

        <grid name="ListProducts" list-name="listIt"
              paginate-target="main" odd-row-style="alternate-row"
              default-entity-name="Product" separate-columns="true"
            header-row-style="header-row-2"  default-table-style="basic-table hover-bar" >

            <actions>
                <entity-condition entity-name="Product">
                    <order-by field-name="productId"/>
                </entity-condition>
            </actions>

            <field name="productId" title="Product Id"><display/></field>
            <field name="productName" title="Product Name"><display/></field>
            <field name="productTypeId" title="Product Type"><display/></field>
            <field name="isVirtual" title="is Virtual ?"><display/></field>
            <field name="isVariant" title="is Variant ?"><display/></field>
        </grid>

    <grid name="ListProductFeatures" list-name="listIt" paginate-target="features" default-entity-name="ProductFeature"
          separate-columns="true" header-row-style="head-row-2" default-table-style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="ProductFeature">
                <condition-expr field-name="productFeatureId" operator="like" value="FEAT%"/>
            </entity-condition>
        </actions>
        <field name="productFeatureId" title="Feature ID"><display/></field>
        <field name="productFeatureTypeId" title="Feature Type"><display/></field>
        <field name="description" title="Feature Description"><display/></field>

        <field name="editLink" title=" " widget-style="buttontext">
            <hyperlink description="Edit" target="EditFeature" also-hidden="false">
                <parameter param-name="productFeatureId"/>
            </hyperlink>
        </field>
        <field name="deleteLink" title=" " widget-style="buttontext">
            <hyperlink description="Delete" target="deleteProductFeature" also-hidden="false">
                <parameter param-name="productFeatureId"/>
            </hyperlink>
        </field>

    </grid>

    <grid name="ListProductCategories" list-name="listIt" paginate-target="categories" default-entity-name="ProductCategory"
          separate-columns="true" header-row-style="header-row-2" default-table-style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="ProductCategory">
                <condition-expr field-name="productCategoryId" operator="like" value="CAT_%"/>
            </entity-condition>
        </actions>
        <field name="productCategoryId" title="Category ID"><display/></field>
        <field name="productCategoryTypeId" title="Category Type"><display/></field>
    </grid>

    <form name="EditProductFeature" type="single" target="updateProductFeature" default-map-name="feature" default-entity-name="ProductFeature">
        <!-- If productFeatureId is empty, it will route to create. If it has a value, it routes to update. -->
        <alt-target use-when="feature==null" target="createProductFeature"/>
        <auto-fields-service service-name="updateProductFeature"/>
        <field name="productFeatureTypeId" title="Feature Type">
            <drop-down allow-empty="false">
                <entity-options entity-name="productFeatureType" key-field-name="productFeatureTypeId"
                                description="${descript}[${productFeatureTypeId}]">
                    <entity-order-by field-name="description"/>
                </entity-options>
            </drop-down>
        </field>

        <!-- We don't want them manually typing IDs, so we hide it on create, and show it as display-only on edit -->
        <field name="productFeatureId" use-when="feature!=null"><display/></field>
        <field name="productFeatureId" use-when="feature==null"><text/></field>
        
        <field name="submitButton" title="Save">
            <submit button-type="button"/>
        </field>
    </form>
</forms>