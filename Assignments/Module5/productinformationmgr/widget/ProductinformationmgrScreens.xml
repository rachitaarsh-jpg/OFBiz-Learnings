<screens xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-0Screen" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Screen http://ofbiz.apache.org/dtds/widget-screen.xsd">

    <screen name="main">
        <section>
            <actions>
                <set field="headerItem" value="main"/><!-- this highlights the selected menu-item with name "main" -->
                <set field="titleProperty" value="Product Information Manager"/>
            </actions>


            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <container style="screenlet">
                            <container style="screenlet-title-bar">
                                <label style="h3">List of Products</label>
                            </container>
                            <container style="screenlet-body">
                                <include-grid name="ListProducts" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <screen name="features">
        <section>
            <actions>
                <set field="headerItem" value="features"/>
                <set field="titleProperty" value="Product Features"/>
            </actions>

                <widgets>
                    <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <container style="screenlet">
                                <container style="screenlet-title-bar">
                                    <label style="h3">List of Features</label>
                                </container>
                                <container style="screenlet-body">
                                    <link target="EditFeature" text="Create New Feature" style="buttontext"/>
                                    <include-grid name="ListProductFeatures" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </container>
                            </container>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
        </section>
    </screen>

    <screen name="categories">
        <section>
            <actions>
                <set field="headerItem" value="categories"/>
                <set field="titleProperty" value="Prodcut Categories"/>
            </actions>

            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <container style="screenlet">
                            <container style="screenlet-title-bar">
                                <label style="h3">List of Categories</label>
                            </container>
                            <container style="screenlet-body">
                                <include-grid name="ListProductCategories"  location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <screen name="EditFeature">
        <section>
            <actions>
                <set field="headerItem" value="features"/>
                <set field="titleProperty" value="Create / Edit Feature"/>
                <!-- This automatically fetches the feature from the DB if a productFeatureId is passed in the URL -->
                <entity-one entity-name="ProductFeature" value-field="feature"/>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <container style="screenlet">
                            <container style="screenlet-title-bar"><label style="h3">Feature Details</label></container>
                            <container style="screenlet-body">
                                <include-form name="EditProductFeature" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

</screens>